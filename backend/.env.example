# ═══════════════════════════════════════════════════════════════════════════
# FlowCity Backend — Environment Variables (PRODUCTION template)
# Copy to .env and fill in all required values before running.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (PostgreSQL / AWS RDS) ──────────────────────────────────────
DATABASE_URL=postgres://flowcity:CHANGE_ME@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/flowcity
DB_HOST=your-rds-endpoint.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=flowcity
DB_PASSWORD=CHANGE_ME
DB_NAME=flowcity

# ── Authentication (JWT) ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_EXPIRES_IN=7d

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://flowcity.app,https://staging.flowcity.app

# ── Monitoring & Error Tracking ───────────────────────────────────────────
SENTRY_DSN=https://CHANGE_ME@o0.ingest.sentry.io/0
DATADOG_API_KEY=CHANGE_ME
DATADOG_APP_KEY=CHANGE_ME
DD_SERVICE=flowcity-backend
DD_ENV=production
DD_VERSION=1.0.0

# ── Real-time Messaging (Kafka/MQTT) ─────────────────────────────────────
KAFKA_CLIENT_ID=flowcity-server
KAFKA_BROKERS=localhost:9092
MQTT_BROKER_URL=mqtt://localhost:1883

# ── Machine Learning Models ───────────────────────────────────────────────
LSTM_MODEL_URL=https://models.flowcity.com/lstm/model.json
XGBOOST_MODEL_URL=https://models.flowcity.com/xgboost/model.json
PROPHET_MODEL_URL=https://models.flowcity.com/prophet/model.json

# ── Google Maps Platform ──────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=CHANGE_ME

# ── Open-Meteo (free, no key) ─────────────────────────────────────────────
ENABLE_WEATHER=true

# ── BEST Bus GTFS-RT ──────────────────────────────────────────────────────
BEST_GTFS_RT_URL=https://gtfs.best-undertaking.com/realtime/vehiclepositions
BEST_GTFS_STATIC_URL=https://gtfs.best-undertaking.com/static/gtfs.zip

# ── Mumbai Metro (MMRDA) ──────────────────────────────────────────────────
MMRDA_API_KEY=CHANGE_ME
MMRDA_API_BASE_URL=https://api.mmrda.maharashtra.gov.in/v1

# ── Indian Railways (RapidAPI) ────────────────────────────────────────────
IRCTC_API_KEY=CHANGE_ME
IRCTC_API_BASE_URL=https://indian-railway-irctc.p.rapidapi.com

# RailRadar (alternative to IRCTC/RapidAPI for live train tracking)
RAILRADAR_API_KEY=your_railradar_api_key_here
RAILRADAR_API_BASE_URL=https://api.railradar.org

# ── Geocoding (Geoapify) ──────────────────────────────────────────────────
GEOAPIFY_API_KEY=CHANGE_ME

# ── Cab APIs ─────────────────────────────────────────────────────────────
UBER_SERVER_TOKEN=CHANGE_ME
OLA_API_KEY=CHANGE_ME
OLA_API_BASE_URL=https://devapi.olacabs.com/v1

# ── S3 Backups ────────────────────────────────────────────────────────────
BACKUP_S3_BUCKET=flowcity-backups-prod
BACKUP_RETAIN_DAYS=30

# ── Trust Score Thresholds (externalized from code) ───────────────────────
TRUST_SCORE_SAFE_THRESHOLD=80
TRUST_SCORE_RISKY_THRESHOLD=40
TRUST_SCORE_CACHE_TTL_MS=300000

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME
