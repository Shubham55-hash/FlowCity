# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/flowcity
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=flowcity

# Authentication (JWT)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Machine Learning Models
LSTM_MODEL_URL=https://models.flowcity.com/lstm/model.json
XGBOOST_MODEL_URL=https://models.flowcity.com/xgboost/model.json
PROPHET_MODEL_URL=https://models.flowcity.com/prophet/model.json

# Real-time Messaging (Kafka/MQTT)
KAFKA_CLIENT_ID=flowcity-server
KAFKA_BROKERS=localhost:9092
MQTT_BROKER_URL=mqtt://localhost:1883

# Job Queues (Bull/Redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
