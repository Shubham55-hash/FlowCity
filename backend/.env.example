# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/flowcity
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=flowcity

# Authentication (JWT)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Machine Learning Models
LSTM_MODEL_URL=https://models.flowcity.com/lstm/model.json
XGBOOST_MODEL_URL=https://models.flowcity.com/xgboost/model.json
PROPHET_MODEL_URL=https://models.flowcity.com/prophet/model.json

# Real-time Messaging (Kafka/MQTT)
KAFKA_CLIENT_ID=flowcity-server
KAFKA_BROKERS=localhost:9092
MQTT_BROKER_URL=mqtt://localhost:1883

# Job Queues (Bull/Redis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── Ghost Commute: Real API Integration ────────────────────────────────────

# Google Maps Platform (https://console.cloud.google.com/)
# Enable: Directions API, Distance Matrix API, Routes API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenRouteService (free tier: https://openrouteservice.org/dev/#/login)
# Alternative to Google Maps — 2000 req/day free
OPENROUTE_API_KEY=your_openrouteservice_api_key_here

# Open-Meteo (https://open-meteo.com/) — FREE, no key needed
# Set ENABLE_WEATHER=true to use real weather in delay predictions
ENABLE_WEATHER=true
# OPEN_METEO_BASE_URL defaults to https://api.open-meteo.com/v1/forecast

# Mumbai GTFS / BEST Bus Real-time (https://otd.delhi.gov.in or local GTFS)
# Feed for real Mumbai BEST bus schedules (GTFS-RT protobuf)
BEST_GTFS_RT_URL=https://gtfs.best-undertaking.com/realtime/vehiclepositions
BEST_GTFS_STATIC_URL=https://gtfs.best-undertaking.com/static/gtfs.zip

# Mumbai Metro (MMRDA) Open Data (if available in your tier)
# https://mmrda.maharashtra.gov.in/
MMRDA_API_KEY=your_mmrda_api_key_here
MMRDA_API_BASE_URL=https://api.mmrda.maharashtra.gov.in/v1

# Indian Railways (CRIS / RailYatri / RapidAPI)
# https://rapidapi.com/collection/indian-railways-api
IRCTC_API_KEY=your_irctc_or_rapidapi_key_here
IRCTC_API_BASE_URL=https://indian-railway-irctc.p.rapidapi.com

# Nominatim / Geoapify for geocoding (free)
# https://www.geoapify.com/ — 3000 req/day free
GEOAPIFY_API_KEY=your_geoapify_api_key_here

# Uber / Ola ride-time estimates (optional, for cab alternative ETA)
UBER_SERVER_TOKEN=your_uber_server_token_here
OLA_API_KEY=your_ola_api_key_here
OLA_API_BASE_URL=https://devapi.olacabs.com/v1
