# ═══════════════════════════════════════════════════════════════════════════
# FlowCity Frontend — Environment Variables (PRODUCTION template)
# Vite injects VITE_* variables at build time into the bundle.
# ═══════════════════════════════════════════════════════════════════════════

# Backend API base URL (no trailing slash)
# No trailing slash; /api is added in code (e.g. http://localhost:5000)
VITE_API_URL=http://localhost:5000

# Socket.io server URL
VITE_SOCKET_URL=https://flowcity.app

# Sentry DSN for frontend error tracking
VITE_SENTRY_DSN=https://CHANGE_ME@o0.ingest.sentry.io/0

# Google Maps browser key — required for "Google" basemap on Safety Map / Ghost route map.
# In Google Cloud: enable "Maps JavaScript API", link a billing account, create an API key,
# and under Key restrictions add Website restrictions: http://localhost:3000/* (and your prod origin).
# If the map shows "Something went wrong", use Safety Map's "OpenStreetMap" toggle or fix the key.
VITE_GOOGLE_MAPS_API_KEY=CHANGE_ME

# Gemini AI (server-side injection only; do not expose raw key in prod builds)
GEMINI_API_KEY=CHANGE_ME

# App canonical URL (for Open Graph, OAuth callbacks)
APP_URL=https://flowcity.app
